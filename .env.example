# Токен бота от @BotFather
BOT_TOKEN=8297955114:AAEW8qDEMbHhqxv3yq-6_rOb7O1HLzL3gas

# Каналы через запятую: @username или числовой id (-100...)
CHANNELS=-1004437187157

# Как часто снимать число подписчиков, минуты
SNAPSHOT_INTERVAL_MIN=60

# Путь к файлу базы данных
DB_PATH=stats.db

# --- MTProto / Telethon (просмотры, реакции, комментарии) ---
# Получить на https://my.telegram.org -> API development tools
API_ID=
API_HASH=
SESSION_NAME=user_session
# Сколько последних постов опрашивать
POSTS_LIMIT=4
# Период повторного сбора в режиме --loop, минуты
POLL_MIN=30

# --- Прокси (если Telegram заблокирован в вашей сети) ---
# PROXY_TYPE: socks5 | socks4 | http   (пусто = без прокси)
PROXY_TYPE=
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# --- Веб-скрапер (обход my.telegram.org, web_scraper.py) ---
# Каналы задаются НАЗВАНИЯМИ (для приватных так удобнее)
CHANNEL_TITLES=Мой канал,Второй канал
# Прокси для Playwright целиком строкой, напр. socks5://host:port или http://host:port
WEB_PROXY=
# Папка с сессией браузера (логин сохраняется здесь)
USER_DATA_DIR=tg_web_profile
POSTS_LIMIT=4
DB_PATH=stats.db
