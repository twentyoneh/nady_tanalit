# === Веб-скрапер (WebZ /a/), маршрут в обход my.telegram.org ===

# Названия каналов через запятую (как видно в Telegram). Открываются авто-поиском.
CHANNEL_NAMES=test

# Сколько последних постов собирать
POSTS_LIMIT=4

# Прокси для Playwright. При VPN оставьте ПУСТЫМ.
WEB_PROXY=
PROXY_USER=
PROXY_PASS=

# Папка с сессией браузера WebZ (логин хранится здесь)
USER_DATA_DIR=tg_web_profile_a

# Файл базы данных
DB_PATH=stats.db

# --- Ниже не нужно для веб-маршрута (оставьте пустым) ---
BOT_TOKEN=
CHANNELS=
API_ID=
API_HASH=
